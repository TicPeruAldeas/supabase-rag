# Bot RAG de WhatsApp de ALDEAS INFANTILES SOS (multi-país, tablas knowledge_*)
# Copia este archivo a .env y completa los valores. NO subas .env a git.

# ── Supabase (base de datos compartida) ──────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Modelos ──────────────────────────────────────────────────────────
OPENAI_API_KEY=            # embeddings text-embedding-3-small
ANTHROPIC_API_KEY=         # Claude (generación y reranking)

# ── WhatsApp / Meta ──────────────────────────────────────────────────
META_APP_SECRET=           # App Secret de Meta (valida la firma del webhook)
WHATSAPP_VERIFY_TOKEN=     # el que definas; debe coincidir con el webhook en Meta
# Un par por país (XX = código ISO de 2 letras: PE, CO, ...):
WHATSAPP_PHONE_NUMBER_ID_PE=
WHATSAPP_TOKEN_PE=
# WHATSAPP_PHONE_NUMBER_ID_CO=
# WHATSAPP_TOKEN_CO=

# ── Seguridad de ingestión y API ─────────────────────────────────────
INGEST_SECRET=             # Bearer para POST /ingest-row y /ask
# ASK_SECRET=              # opcional; si falta, /ask usa INGEST_SECRET

# ── Panel de conversaciones (/admin) ─────────────────────────────────
ADMIN_PASSWORD=            # contraseña Basic Auth del panel /admin (si falta, usa INGEST_SECRET)

# ── Opcionales ───────────────────────────────────────────────────────
# Edad máxima (segundos) de un mensaje entrante antes de descartarlo (default 180)
# MAX_INBOUND_MESSAGE_AGE_SECONDS=180
# Horas de vigencia del consentimiento (botón "Continuar"); pasado ese tiempo
# de inactividad se vuelve a pedir (default 24)
# CONSENT_SESSION_HOURS=24

# ── Langfuse (observabilidad, opcional) ──────────────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
